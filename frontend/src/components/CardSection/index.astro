---
import Group2 from "/ATSResumeTest/Group 2.svg";
import Group3 from "/ATSResumeTest/Group 3.svg";

const card = [
    {
        "cardImg": "Cloud.svg",
        "cardAlt": "Cloud Icon - Representing Unlimited ATS Resume Scans",
        "cardTitle": "Unlimited scans",
        "cardText": "Test multiple versions of your resume tailored for different job descriptions or industry tracks, and monitor improvements over time."
    },
    {
        "cardImg": "Free.svg",
        "cardAlt": "Free Icon - Representing Free Resume Scanner",
        "cardTitle": "Instant analysis",
        "cardText": "Receive a complete, instant checklist scoring your page length, section presence, tables, formatting compliance, and contact details."
    },
    {
        "cardImg": "Chart.svg",
        "cardAlt": "Chart Icon - Representing Effective Resume Scanner",
        "cardTitle": "Tailored guidance",
        "cardText": "Get custom skill keyword additions and curated online courses designed to address requirements gaps and boost search indexing."
    },
]
---

<section id="Features" class="relative bg-[#0C1030] w-full px-6 md:px-16 py-20 overflow-hidden max-w-6xl mx-auto">
    <img
        src={Group3}
        class="absolute w-auto h-[100%] top-0 left-0 opacity-20 pointer-events-none"
    />

    <img
        src={Group2}
        class="absolute w-auto h-[100%] top-0 right-0 opacity-20 pointer-events-none"
    />
    
    <div class="relative z-10">
        <div class="p-0 md:w-[65%] text-[#FCFCFD]">
            <h2 class="text-3xl sm:text-5xl font-rubik font-bold tracking-tight bg-gradient-to-r from-white via-slate-100 to-indigo-200 bg-clip-text text-transparent leading-tight pb-2">
                Features of Resume Screener
            </h2>
            <p class="text-justify py-4 text-base md:text-lg text-gray-400 font-light leading-relaxed">
                Our platform provides detailed, actionable insights into your resume. From layout checks (such as single-column verification and font validation) to formatting check details (such as table detection and structure parsing), our screener scores your resume using standard ATS scoring metrics. It highlights keywords in your content and matches them against domain profiles to suggest target job positions, along with course and skill recommendations to fill any gaps.
            </p>
            <a href="/scan"
                class="inline-block bg-[#6938ef] hover:bg-[#5629D4] text-white py-3 px-8 rounded-xl font-bold transition-all duration-300 shadow-md hover:shadow-[0_0_20px_rgba(105,56,239,0.3)] active:scale-95 mt-4"
            >
                Resume Screener Tool
            </a>
        </div>
    </div>

    <div class="py-14 flex flex-col md:flex-row items-stretch gap-8">
        { card.map(item => (
                <div class="relative z-10 p-6 md:p-8 bg-gradient-to-b from-[#24284d]/90 to-[#121635]/95 hover:from-[#2e3362] border border-white/5 hover:border-white/20 rounded-2xl flex-1 flex flex-col gap-4 shadow-xl hover:-translate-y-2 transition-all duration-300 shadow-indigo-950/20">
                    <img 
                        src={`/CardSection/${item.cardImg}`} alt={item.cardAlt}
                        class="w-16 h-16 object-contain select-none"
                    />

                    <h3 class="font-rubik text-white font-bold text-2xl tracking-tight">{item.cardTitle}</h3>
                    <p class="block font-sans font-light mt-auto text-gray-300 text-sm md:text-base leading-relaxed">{item.cardText}</p>
                </div>
            )) }
    </div>
</section>