---
type Guidelines = {
  title: string;
  data: string;
  open?: boolean;
};

const accordions: Guidelines[] =[
    {
      title: "Avoid using tables & grids",
      data : "Tables can confuse applicant tracking systems, which parse row-by-row. Use simple tab stops and clean lists instead of grid lines."
    },
    {
      title: "Make use of standard fonts",
      data : "ATS scanners require standard web-safe fonts like Inter, Arial, Calibri, or Times New Roman. Avoid custom or download-only fonts."
    },
    {
      title: "Use a single-column layout",
      data : "Multi-column resumes often get read left-to-right across the columns by ATS software. Stick to a clean, single-column design."
    },
    {
      title: "Use conventional section titles",
      data : "Search algorithms specifically query standard section headings like 'Work Experience', 'Education', and 'Skills'. Keep it simple and clear."
    },
    {
      title: "No scanned documents or diagrams",
      data : "Scanned resumes or images are parsed as flat images, resulting in zero extracted text. Always upload a text-selectable PDF."
    },
  ];
---

<section class = "py-24 px-6 md:px-16 flex flex-col bg-no-repeat bg-right-bottom object-cover w-full" style="background-image: url(../GuidelinesSection/Group1.svg);  background-color: #0C1030;">
    <div class="text-white text-center mb-12">
      <h2 class="text-3xl sm:text-5xl font-rubik tracking-tight font-bold bg-gradient-to-r from-white via-slate-100 to-indigo-200 bg-clip-text text-transparent leading-tight">
        How do I Make sure my resume is <br>ATS-compliant?
      </h2>
      <p class="text-md sm:text-lg text-gray-400 font-light mt-4 max-w-xl mx-auto">
        Here are some guidelines you should follow to ensure your resume gets correctly scanned by all applicant tracking systems.
      </p>
    </div>
          <div class="flex flex-col gap-4 md:w-3/5 lg:w-2/4 mx-auto border border-white/10 rounded-2xl p-6 md:p-10 shadow-2xl bg-white/5 backdrop-blur-md">
            {
              accordions.map(({ title, data, open }) => (
                <details open={open} class="border-box rounded-xl group border border-white/10 transition-all duration-300 bg-white/5 hover:bg-white/10">
                  <summary class="flex items-center justify-between text-white p-4 px-6 text-base font-semibold cursor-pointer select-none">
                    {title}
                    {<img src="../GuidelinesSection/Icon.svg" alt="Down arrow" class="h-4 w-4 transition-transform duration-300 group-open:rotate-180 "/>}
                  </summary>
                  <div class="p-5 pt-0 border-t border-white/5 mt-1">
                    <p class="text-gray-300 font-inter text-sm leading-relaxed">
                      {data}
                    </p>
                  </div>
                </details>
              ))
            }
          </div>
</section>          
 