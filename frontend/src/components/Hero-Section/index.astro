---
import data from "./data";
---

<div class="bg-[#0C1030] w-full flex flex-col items-center relative overflow-hidden py-16">
    <!-- Glowing background radial blur -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#6938EF]/10 rounded-full blur-[140px] pointer-events-none z-0"></div>

    <div class="mt-4 z-20 w-full max-w-6xl mx-auto flex flex-col items-center">
        {
            data.map((ele, index) => (
                <div class="flex flex-col items-center">
                    <div class="text-white max-w-4xl px-4">
                        <h1 class="font-rubik font-extrabold text-5xl md:text-7xl tracking-tight text-center leading-tight bg-gradient-to-r from-white via-slate-100 to-indigo-300 bg-clip-text text-transparent pb-4">
                            {ele.heading}
                        </h1>
                    </div>
                    <div class="w-10/12 md:w-7/12 text-white mt-4">
                        <p class="text-[#D0D5DD] font-normal text-lg md:text-xl leading-relaxed text-center">{ele.description}</p>
                    </div>
                </div>
            ))
        }
        <div class=" flex flex-col sm:flex-row text-white  items-center justify-center gap-6 mt-8">
            <a href="/scan" class=" bg-[#6938EF] inline-flex items-center justify-center w-auto rounded-xl px-8 py-4 text-lg font-bold leading-6 text-white border border-transparent hover:bg-[#5629D4] hover:shadow-[0_0_30px_rgba(105,56,239,0.4)] active:scale-95 transition-all duration-300">
                Resume Screener Tool
            </a>
            <a href="mailto:j4innovate@gmail.com" class=" bg-[#FFFFFF10] w-auto px-8 py-4 flex items-center justify-center rounded-xl hover:bg-[#ffffff17] transition-all duration-300 font-bold border border-white/10 text-lg hover:shadow-[0_0_20px_rgba(255,255,255,0.05)]">
                Contact Us
            </a>
        </div>
        <div class="mt-20 w-full max-w-5xl px-4">
            <div class="p-3 rounded-2xl bg-white/5 backdrop-blur-md border border-white/10 shadow-2xl shadow-indigo-950/40">
                <img src="/Hero-section/image.png" alt="heroSection" class="rounded-xl border border-white/10 shadow-2xl w-full">
            </div>
        </div>
    </div>
    <img src="/Hero-section/right.svg" class=" absolute right-0 z-10 w-3/5 md:w-auto opacity-40" alt="" >
    <img src="/Hero-section/left.svg" class="absolute left-0 z-10 w-3/5 md:w-auto opacity-40" alt="" > 
</div>

