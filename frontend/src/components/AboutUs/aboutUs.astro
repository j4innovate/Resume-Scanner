---
import aboutUsImg from "/AboutUs/about-us.svg"
import arrow from "/AboutUs/arrow-icon.svg"
---

<section id="AboutUs" class="w-full bg-[#0C1030] flex flex-col lg:flex-row items-center justify-between gap-12 py-20 px-6 md:px-16 max-w-6xl mx-auto">
    <div class="w-full lg:w-1/2 overflow-hidden rounded-2xl bg-white/5 border border-white/5 p-4 shadow-2xl shadow-indigo-950/20">
        <img src={aboutUsImg} alt="about-us" class="w-full hover:scale-105 transition-transform duration-500" />
    </div>
    <div class="w-full lg:w-1/2 flex flex-col items-start gap-4 md:gap-6">
        <h2 class="text-4xl md:text-5xl font-rubik font-bold tracking-tight text-white bg-gradient-to-r from-white via-slate-200 to-indigo-200 bg-clip-text text-transparent">
            About Us
        </h2>
        <p class="text-base md:text-lg font-normal leading-relaxed text-[#D0D5DD] text-justify">
            Our free resume scanner ensures that your resume is ATS compliant and will be read correctly by Applicant Tracking Systems (ATS) and resume screening software. It provides detailed feedback on key criteria important to recruiters and hiring managers. Maximize your chances of getting noticed by using our resume scanner today. Don't let your resume be overlooked - get valuable insights and make a strong impression with our ATS compliance evaluation.
        </p>
        <a href="/scan" class="inline-flex items-center gap-2 bg-[#6938EF] hover:bg-[#5629D4] transition-all duration-300 font-bold text-white px-6 py-3.5 rounded-xl shadow-lg hover:shadow-[0_0_20px_rgba(105,56,239,0.3)] active:scale-95">
            Start Resume Test
            <img src={arrow} class="w-4 h-4 ml-1"></img>
        </a>
    </div>
</section>